import { supabase } from '../lib/supabase';

async function getTopProducts() {
  // L-Fix: drna .select('*') bach i-jib kolchi (prix, smia, tsawer...)
  const { data, error } = await supabase
    .from('products')
    .select('*') 
    .limit(3);

  if (error) {
    console.error('Failed to load products from Supabase', error);
    return { data: [], error: 'Unable to load products right now.' };
  }

  return { data: data ?? [], error: null };
}

async function TopProducts() {
  const { data, error } = await getTopProducts();

  return (
    <section aria-labelledby="top-products-heading" className="products-shell">
      <header className="section-heading">
        <div>
